DOMAIN=iswink
# 生产环境配置
# 租户id
DOMAIN_URL=https://www.iswink.com
NUXT_PUBLIC_TENANT_ID=1
NUXT_APP_TITLE=Love gifts
# 后台接口地址 - 生产服务器
NUXT_API_TARGET_URL=https://api.iswink.com
# WebSocket地址
NUXT_PUBLIC_KEFU_WS_URL=wss://iswink.com/infra/ws
#  Nitro Proxy 代理前缀,useFetch 拼接 URL,简单来说 就是 生产环境走 Nitro 代理时,加入 /app-api 前缀
# API 代理路径（统一使用相对路径，走 Nitro Proxy）
NUXT_API_PROXY_PATH=/app-api
# 生产模式
NODE_ENV=production
DEBUG=false